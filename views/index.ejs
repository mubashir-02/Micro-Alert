<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <meta name="description" content="MicroAlert — Smart road safety and navigation for Chennai. Real-time hazard alerts, AI-powered route scanning, emergency dispatch, and driver safety ratings.">
  <title><%= title %></title>

  <!-- Google Fonts -->
  <link rel="stylesheet" href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700;800&family=JetBrains+Mono:wght@400;500&display=swap">
  <!-- Leaflet CSS -->
  <link rel="stylesheet" href="https://unpkg.com/leaflet@1.9.4/dist/leaflet.css" />
  <!-- App CSS -->
  <link rel="stylesheet" href="/css/style.css">
</head>
<body>

  <!-- Top Navbar -->
  <nav class="top-navbar" id="topNavbar">
    <div class="nav-left">
      <button class="sidebar-toggle" id="sidebarToggle" aria-label="Toggle sidebar">☰</button>
      <div class="nav-brand">
        <div class="nav-logo">⚡</div>
        <div class="nav-brand-text">
          <span class="brand-name">MicroAlert</span>
          <span class="brand-sub">Smart Road Safety</span>
        </div>
      </div>
    </div>
    <div class="nav-center">
      <div class="nav-location" id="navLocation">
        <span class="nav-loc-icon">📍</span>
        <span class="nav-loc-text" id="navLocationText">Chennai, India</span>
      </div>
    </div>
    <div class="nav-right">
      <div class="speed-rating-badge" id="speedBadge" title="Your driving safety rating">
        <div class="speed-stars" id="speedStars">⭐⭐⭐⭐⭐</div>
        <span class="speed-label">5.0</span>
      </div>
      <button class="nav-alert-btn" id="alertBellBtn" onclick="toggleAlertPanel()" aria-label="Alerts">
        <span class="alert-bell">🔔</span>
        <span class="alert-badge" id="alertBadge">0</span>
      </button>
      <a href="/admin" class="nav-admin-link" id="adminPanelLink" title="Admin Panel">🛡️</a>
    </div>
  </nav>

  <!-- Alert Panel Dropdown -->
  <div class="alert-panel" id="alertPanel">
    <div class="alert-panel-header">
      <h3>🔔 Active Alerts</h3>
      <button onclick="toggleAlertPanel()" class="alert-panel-close">✕</button>
    </div>
    <div class="alert-panel-body" id="alertPanelBody">
      <div class="alert-empty">No new alerts</div>
    </div>
  </div>

  <div class="app-container">
    <!-- ─── Sidebar ─────────────────────────────────────────────────────────── -->
    <aside class="sidebar" id="sidebar">
      <div class="sidebar-body">

        <!-- Route Panel -->
        <div class="panel" id="routePanel">
          <div class="panel-header" onclick="togglePanel('routePanel')">
            <div class="panel-title">
              <span class="icon">🗺️</span> Route Risk Scanner
            </div>
            <span class="panel-chevron">▼</span>
          </div>
          <div class="panel-body">
            <form class="route-form" id="routeForm" onsubmit="return false;">
              <div class="input-group autocomplete-wrapper">
                <span class="input-icon">📍</span>
                <input type="text" id="startLocation" placeholder="Start: type any location…" autocomplete="off">
                <div class="autocomplete-dropdown" id="startDropdown"></div>
              </div>
              <div class="input-group autocomplete-wrapper">
                <span class="input-icon">🏁</span>
                <input type="text" id="endLocation" placeholder="End: type any location…" autocomplete="off">
                <div class="autocomplete-dropdown" id="endDropdown"></div>
              </div>
              <div class="route-suggestions">
                <span class="suggestion-chip" onclick="fillRoute('Anna Nagar, Chennai', 'T. Nagar, Chennai')">Anna Nagar → T. Nagar</span>
                <span class="suggestion-chip" onclick="fillRoute('Tambaram, Chennai', 'Adyar, Chennai')">Tambaram → Adyar</span>
                <span class="suggestion-chip" onclick="fillRoute('Chennai Central', 'Marina Beach, Chennai')">Central → Marina</span>
              </div>
              <button type="button" class="btn btn-primary btn-block" id="scanRouteBtn" onclick="scanRoute()">
                🔍 Scan Route for Risks
              </button>
            </form>

            <!-- Route Results -->
            <div class="loading" id="routeLoading">
              <div class="spinner"></div>
              <span class="loading-text">Analyzing route risks with AI…</span>
            </div>

            <!-- Multi-Route Results -->
            <div class="route-results" id="routeResults" style="display:none;">
              <div class="route-results-header">📊 Top 3 Routes</div>
              <div class="route-options" id="routeOptions">
                <!-- Populated by JS -->
              </div>
            </div>

            <div class="alert-box" id="routeAlert">
              <div class="alert-label">⚠️ Condensed Alert</div>
              <div class="alert-text" id="routeAlertText"></div>
              <div class="alert-actions">
                <button class="btn btn-sm btn-secondary" onclick="shareAlert()">📋 Copy Alert</button>
              </div>
            </div>
          </div>
        </div>

        <!-- Risk Prediction Panel -->
        <div class="panel" id="predictionPanel">
          <div class="panel-header" onclick="togglePanel('predictionPanel')">
            <div class="panel-title">
              <span class="icon">⚠️</span> Accident Risk Predictor
            </div>
            <span class="panel-chevron">▼</span>
          </div>
          <div class="panel-body">
            <div class="prediction-display" id="predictionDisplay">
              <div class="prediction-gauge" id="predictionGauge">
                <div class="gauge-circle" id="gaugeCircle">
                  <div class="gauge-value" id="gaugeValue">—</div>
                  <div class="gauge-label" id="gaugeLabel">Risk Score</div>
                </div>
              </div>
              <div class="prediction-details" id="predictionDetails">
                <p class="prediction-hint">Click "Analyze Risk" at your current location</p>
              </div>
            </div>
            <div class="prediction-controls">
              <div class="pred-row">
                <select id="predWeather" class="pred-select">
                  <option value="clear">☀️ Clear</option>
                  <option value="rain">🌧️ Rain</option>
                  <option value="fog">🌫️ Fog</option>
                </select>
                <select id="predRoadType" class="pred-select">
                  <option value="urban">🏙️ Urban</option>
                  <option value="highway">🛣️ Highway</option>
                  <option value="rural">🌾 Rural</option>
                </select>
              </div>
              <button class="btn btn-primary btn-block" onclick="analyzePrediction()">
                🔮 Analyze Risk Here
              </button>
            </div>
          </div>
        </div>

        <!-- Ask About Area Panel -->
        <div class="panel" id="askPanel">
          <div class="panel-header" onclick="togglePanel('askPanel')">
            <div class="panel-title">
              <span class="icon">🤖</span> Ask About This Area
            </div>
            <span class="panel-chevron">▼</span>
          </div>
          <div class="panel-body">
            <p style="font-size: 12px; color: var(--text-secondary); margin-bottom: 10px;">
              Pan the map to any area in Chennai, then click below to get an AI-powered risk analysis.
            </p>
            <button class="btn btn-primary btn-block" id="askAreaBtn" onclick="askAboutMyLocation()">
              🧠 Analyze Current Area
            </button>
            <div class="loading" id="askLoading">
              <div class="spinner"></div>
              <span class="loading-text">AI analyzing risk patterns…</span>
            </div>
            <div class="ask-area-result" id="askResult">
              <div class="answer-label">🧠 AI Analysis</div>
              <div class="answer-text" id="askResultText"></div>
            </div>
          </div>
        </div>

        <!-- Top Risks Panel -->
        <div class="panel" id="risksPanel">
          <div class="panel-header" onclick="togglePanel('risksPanel')">
            <div class="panel-title">
              <span class="icon">🔴</span> Top Risks
            </div>
            <span class="panel-badge" id="riskCount">0</span>
            <span class="panel-chevron">▼</span>
          </div>
          <div class="panel-body">
            <div class="risk-list" id="riskList">
              <!-- Populated by JS -->
            </div>
          </div>
        </div>

        <!-- Report a Risk Panel -->
        <div class="panel collapsed" id="reportPanel">
          <div class="panel-header" onclick="togglePanel('reportPanel')">
            <div class="panel-title">
              <span class="icon">📝</span> Report a Risk
            </div>
            <span class="panel-chevron">▼</span>
          </div>
          <div class="panel-body">
            <form class="report-form" id="reportForm" onsubmit="return false;">
              <div class="form-group">
                <label>Risk Type</label>
                <select id="reportType">
                  <option value="sudden_brake">🛑 Sudden Braking Zone</option>
                  <option value="blind_turn">🔄 Blind Turn</option>
                  <option value="habitual_violation">⚠️ Habitual Violation</option>
                  <option value="accident">💥 Accident Zone</option>
                </select>
              </div>
              <div class="form-group">
                <label>Severity (1-5)</label>
                <select id="reportSeverity">
                  <option value="3">3 – Moderate</option>
                  <option value="1">1 – Minor</option>
                  <option value="2">2 – Low</option>
                  <option value="4">4 – High</option>
                  <option value="5">5 – Critical</option>
                </select>
              </div>
              <div class="form-group">
                <label>Description</label>
                <textarea id="reportDescription" placeholder="Describe the risk in detail..."></textarea>
              </div>
              <div class="form-group">
                <label>Road Name</label>
                <input type="text" id="reportRoadName" placeholder="e.g., Anna Salai">
              </div>
              <div class="form-group">
                <label>Landmark (optional)</label>
                <input type="text" id="reportLandmark" placeholder="e.g., near Spencer Plaza">
              </div>
              <div class="form-group">
                <label>Location</label>
                <div class="location-picker-hint" id="locationPickerHint">
                  📍 Click on the map to pick a location
                </div>
                <div class="picked-coords" id="pickedCoords" style="display:none;">
                  Lat: <span id="pickedLat">—</span>, Lng: <span id="pickedLng">—</span>
                </div>
              </div>
              <div class="form-group">
                <label>Hazard Photo</label>
                <input type="file" id="cameraInput" accept="image/*" capture="environment" style="display:none;" onchange="handleCameraCapture(this)">
                <div class="camera-capture-row">
                  <button type="button" class="btn btn-secondary btn-block camera-btn" onclick="openCamera()">
                    📸 Take Photo / Upload
                  </button>
                </div>
                <div class="photo-preview-container" id="photoPreviewContainer" style="display:none;"></div>
              </div>
              <button type="button" class="btn btn-primary btn-block" onclick="submitReport()">
                📤 Submit Risk Report
              </button>
            </form>
          </div>
        </div>

      </div>
    </aside>

    <!-- ─── Map ─────────────────────────────────────────────────────────────── -->
    <div class="map-container">
      <div id="map"></div>

      <!-- Map Controls -->
      <div class="map-controls">
        <button class="map-control-btn" id="heatmapToggle" onclick="toggleHeatmap()">
          🌡️
          <span class="tooltip">Toggle Heatmap</span>
        </button>
        <button class="map-control-btn" id="emergencyBtn" onclick="showEmergency()">
          🚨
          <span class="tooltip">Emergency Services</span>
        </button>
        <button class="map-control-btn" id="locateBtn" onclick="locateMe()">
          📍
          <span class="tooltip">My Location</span>
        </button>
        <button class="map-control-btn" id="cameraBtn" onclick="openCamera()">
          📷
          <span class="tooltip">Capture Hazard</span>
        </button>
        <button class="map-control-btn" id="centerBtn" onclick="centerMap()">
          🎯
          <span class="tooltip">Center on Chennai</span>
        </button>
      </div>

      <!-- Bottom Cards (over map) -->
      <div class="bottom-cards" id="bottomCards">
        <!-- Route Info Card -->
        <div class="bottom-card route-info-card" id="routeInfoCard" style="display:none;">
          <div class="bcard-header">
            <span class="bcard-icon">🗺️</span>
            <span class="bcard-title">Route Info</span>
          </div>
          <div class="bcard-body">
            <div class="bcard-stat"><span class="bcard-stat-label">ETA</span><span class="bcard-stat-value" id="routeETA">—</span></div>
            <div class="bcard-stat"><span class="bcard-stat-label">Distance</span><span class="bcard-stat-value" id="routeDistance">—</span></div>
            <div class="bcard-stat"><span class="bcard-stat-label">Hazard</span><span class="bcard-stat-value" id="routeHazard">—</span></div>
          </div>
        </div>

        <!-- Emergency Dispatch Card -->
        <div class="bottom-card emergency-card" id="emergencyDispatchCard">
          <div class="bcard-header">
            <span class="bcard-icon">🚨</span>
            <span class="bcard-title">Emergency Dispatch</span>
          </div>
          <div class="bcard-body emergency-btns">
            <button class="dispatch-btn ambulance" onclick="dispatchEmergency('ambulance')" id="dispatchAmbulance">
              <span class="dispatch-icon">🚑</span>
              <span class="dispatch-label">Ambulance</span>
            </button>
            <button class="dispatch-btn police" onclick="dispatchEmergency('police')" id="dispatchPolice">
              <span class="dispatch-icon">👮</span>
              <span class="dispatch-label">Police</span>
            </button>
            <button class="dispatch-btn fire" onclick="dispatchEmergency('fire')" id="dispatchFire">
              <span class="dispatch-icon">🚒</span>
              <span class="dispatch-label">Fire</span>
            </button>
            <button class="dispatch-btn roadside" onclick="dispatchEmergency('roadside')" id="dispatchRoadside">
              <span class="dispatch-icon">🆘</span>
              <span class="dispatch-label">Roadside</span>
            </button>
          </div>
        </div>
      </div>

      <!-- Passive Mic Indicator (always visible, non-intrusive) -->
      <div class="passive-mic-indicator" id="passiveMicIndicator">
        <span class="pmi-dot"></span>
      </div>

      <!-- Voice Assistant FAB -->
      <button class="voice-fab" id="voiceFab" onclick="toggleVoiceAssistant()" aria-label="Voice Assistant">
        <span class="voice-fab-icon" id="voiceFabIcon">🎙️</span>
        <span class="voice-fab-pulse" id="voiceFabPulse"></span>
      </button>

      <!-- Voice Assistant Panel -->
      <div class="voice-panel" id="voicePanel">
        <div class="voice-panel-header">
          <h3>🎙️ Voice Assistant</h3>
          <span class="voice-nlp-badge">🧠 NLP</span>
          <span class="voice-status" id="voiceStatus">Say "wake up" to activate</span>
          <button onclick="closeVoicePanel()" class="voice-panel-close">✕</button>
        </div>
        <!-- Language Selector -->
        <div class="voice-lang-bar">
          <span class="voice-lang-label">🌐 Language:</span>
          <div class="voice-lang-options">
            <button class="lang-option active" data-lang="en" onclick="setVoiceLanguage('en')">EN</button>
            <button class="lang-option" data-lang="hi" onclick="setVoiceLanguage('hi')">हिन्दी</button>
            <button class="lang-option" data-lang="te" onclick="setVoiceLanguage('te')">తెలుగు</button>
            <button class="lang-option" data-lang="ta" onclick="setVoiceLanguage('ta')">தமிழ்</button>
          </div>
        </div>
        <!-- Journey Status Bar -->
        <div class="voice-journey-bar" id="voiceJourneyBar" style="display:none;">
          <div class="journey-indicator">
            <span class="journey-pulse"></span>
            <span class="journey-text" id="journeyStatusText">Journey Active</span>
          </div>
          <button class="journey-stop-btn" onclick="stopJourney()">⏹ End</button>
        </div>
        <div class="voice-transcript" id="voiceTranscript">
          <div class="voice-msg system">👋 Hi! Say <strong>"wake up"</strong> to activate me.
            <br><br>🧠 <strong>I understand natural language!</strong> Just talk to me like a friend:
            <br>• "There's a pothole near the school"
            <br>• "Is it safe near Marina Beach?"
            <br>• "Take me to the airport avoiding risky spots"
            <br>• "Start journey to T. Nagar"
            <br>• "Any new warnings today?"
            <br><br>📸 <strong>Capture hazards:</strong> "Take a photo"
            <br>🚑 <strong>Emergency:</strong> "Call ambulance"
            <br>🌐 <strong>Languages:</strong> English · Hindi · Telugu · Tamil
          </div>
        </div>
        <div class="voice-controls">
          <button class="voice-listen-btn" id="voiceListenBtn" onclick="startListening()">
            <span class="mic-icon" id="micIcon">🎤</span>
            <span id="voiceListenLabel">Tap to Listen</span>
          </button>
        </div>
      </div>

      <!-- Emergency Overlay -->
      <div class="emergency-overlay" id="emergencyOverlay">
        <div class="emergency-header">
          <h3>🚨 Emergency Services</h3>
          <button class="emergency-close" onclick="closeEmergency()">✕</button>
        </div>
        <div class="emergency-list" id="emergencyList">
          <!-- Populated by JS -->
        </div>
      </div>
    </div>
  </div>

  <!-- Toast Container -->
  <div class="toast-container" id="toastContainer"></div>

  <!-- Dispatch Confirmation Modal -->
  <div class="dispatch-modal" id="dispatchModal">
    <div class="dispatch-modal-content">
      <div class="dispatch-modal-icon" id="dispatchModalIcon">🚑</div>
      <h2 id="dispatchModalTitle">Dispatching Ambulance</h2>
      <p id="dispatchModalText">Sending your GPS coordinates and route info...</p>
      <div class="dispatch-modal-spinner">
        <div class="spinner"></div>
      </div>
      <button class="btn btn-secondary" onclick="closeDispatchModal()" id="dispatchModalClose" style="display:none;">Close</button>
    </div>
  </div>

  <!-- Scripts -->
  <script src="https://unpkg.com/leaflet@1.9.4/dist/leaflet.js"></script>
  <script src="https://unpkg.com/leaflet.heat@0.2.0/dist/leaflet-heat.js"></script>
  <script src="/socket.io/socket.io.js"></script>
  <script src="/js/map.js"></script>
  <script src="/js/voice.js"></script>
  <script src="/js/chat.js"></script>
</body>
</html>
