# Database
# Use either DATABASE_URL for cloud MySQL, or the MYSQL_* fields below.
# Example: mysql://user:password@host:3306/microalert
DATABASE_URL=

MYSQL_DB=microalert
MYSQL_USER=root
MYSQL_PASSWORD=your_password
MYSQL_HOST=localhost
MYSQL_PORT=3306
MYSQL_SSL=false

# LLM API Configuration
# Set LLM_PROVIDER to: nvidia, openai, or groq
LLM_PROVIDER=nvidia

# Option 1: NVIDIA NIM (default)
NVIDIA_API_KEY=nvapi-your-nvidia-key-here

# Option 2: OpenAI
# OPENAI_API_KEY=sk-your-openai-key-here

# Option 3: Groq
# GROQ_API_KEY=gsk_your-groq-key-here

# Server
PORT=3000

# Database sync behavior
# Set to true only when you want Sequelize to auto-alter tables on boot.
DB_SYNC_ALTER=false
DB_LOGGING=false
